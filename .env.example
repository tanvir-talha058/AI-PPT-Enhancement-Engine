# ==================== AI PROVIDERS ====================
# Configure at least ONE of the following providers:
# Priority order: Gemini → OpenRouter → HuggingFace

# GEMINI (Free tier: 15 req/min, 1M tokens/day)
# Get key: https://ai.google.dev (free tier - requires verification)
# Status: FREE but rate-limited
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_SECONDS=2

# OPENROUTER (Recommended backup: $0.04-0.15 per 1M tokens)
# Get key: https://openrouter.ai
# Status: PAID (cheap, reliable, no rate limits)
# Recommended when Gemini quota exhausted
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# HUGGINGFACE (Free tier: rate-limited)
# Get key: https://huggingface.co/settings/tokens
# Status: FREE but can be unreliable
# Use models: mistralai/Mistral-7B-Instruct-v0.1 or meta-llama/Llama-2-7b-chat-hf
# Note: flan-t5-large is deprecated (410 Gone error)
HF_API_KEY=
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# ==================== QUEUE & REDIS ====================
USE_REDIS=auto
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=ppt_tasks

# ==================== FILE MANAGEMENT ====================
MAX_FILE_SIZE_MB=50
FILE_CLEANUP_AGE_HOURS=24

# ==================== RATE LIMITING ====================
RATE_LIMIT_PER_HOUR=100

# ==================== LOGGING ====================
LOG_LEVEL=INFO

# ==================== TIMEOUTS ====================
REQUEST_TIMEOUT=60
